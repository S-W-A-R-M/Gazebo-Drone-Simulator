# docker/Dockerfile
FROM ros:jazzy-ros-base

# ── System deps ──────────────────────────────────────────────────────────────
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core build tools
    build-essential cmake git python3-pip python3-colcon-common-extensions \
    python3-rosdep python3-vcstool \
    # Gazebo Harmonic + ROS-GZ bridge
    ros-jazzy-ros-gz \
    # ROS nav / sensor essentials
    ros-jazzy-nav2-bringup \
    ros-jazzy-sensor-msgs \
    ros-jazzy-geometry-msgs \
    ros-jazzy-tf2-ros \
    # GUI / display support (for Gazebo rendering via WSLg)
     libglx-mesa0 libglu1-mesa mesa-utils x11-apps \
    # ROS dev/demo tools
    ros-jazzy-demo-nodes-cpp \
    ros-jazzy-demo-nodes-py \
    ros-jazzy-rqt \
    ros-jazzy-rqt-common-plugins \
    ros-jazzy-rviz2 \
    # Useful dev tools
    vim tmux wget curl \
    && rm -rf /var/lib/apt/lists/*

# ── rosdep init ──────────────────────────────────────────────────────────────
RUN rosdep init 2>/dev/null || true && rosdep update

# ── Non-root user (matches your WSL UID to avoid permission issues) ──────────
ARG USERNAME=swarm
ARG USER_UID=1000
ARG USER_GID=1000

RUN groupmod -n $USERNAME $(getent group $USER_GID | cut -d: -f1) \
    && usermod -l $USERNAME -d /home/$USERNAME -m $(getent passwd $USER_UID | cut -d: -f1) \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER $USERNAME
WORKDIR /home/$USERNAME

# ── Shell convenience ────────────────────────────────────────────────────────
RUN echo "source /opt/ros/jazzy/setup.bash" >> ~/.bashrc \
    && echo "source /swarm_ws/install/setup.bash 2>/dev/null || true" >> ~/.bashrc \
    && echo "export ROS_DOMAIN_ID=42" >> ~/.bashrc

COPY --chown=$USERNAME docker/windows /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]